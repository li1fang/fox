{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fox.local/schemas/entry.schema.json",
  "title": "Fox Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "occurred_at",
    "timezone",
    "status",
    "evidence",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable unique entry id."
    },
    "type": {
      "type": "string",
      "enum": ["meal", "medical", "workout", "expense", "note"]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "timezone": {
      "type": "string",
      "examples": ["Asia/Bangkok", "America/Los_Angeles"]
    },
    "title": {
      "type": "string"
    },
    "raw_text": {
      "type": "string",
      "description": "Original user text, OCR output, or transcript."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "extracted", "needs_review", "confirmed"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "extracted_json": {
      "type": "object",
      "description": "AI-generated draft payload matching the entry type."
    },
    "confirmed_json": {
      "type": "object",
      "description": "User-confirmed payload matching the entry type."
    },
    "extraction_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "uri", "created_at"],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["image", "pdf", "audio", "text", "receipt", "prescription"]
        },
        "uri": {
          "type": "string"
        },
        "mime_type": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}

